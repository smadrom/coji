# --- Database ---
DATABASE_URL=postgres://coji:coji@127.0.0.1:5432/coji

# --- API server ---
PORT=3001

# --- Provider selection (default to free fakes; CI never spends money) ---
# image: noop | gemini
IMAGE_PROVIDER=noop
# animation: noop | heygen
ANIMATION_PROVIDER=noop
# render: noop | ffmpeg | remotion-local
RENDER_PROVIDER=noop
# storage: local-fs | s3
STORAGE_PROVIDER=local-fs

# --- Local-fs storage fake ---
STORAGE_LOCAL_DIR=.storage

# --- Job runner / lease ---
LEASE_TTL_MS=60000
RUNNER_ENABLED=false
RUNNER_TICK_MS=1000
RUNNER_DEV_TICK_ROUTE=false
RECONCILE_STALE_MS=30000
RECONCILE_MAX_AGE_MS=1800000

# --- Credits ---
CREDIT_USD_RATE=1

# --- Auth (Better Auth, task #22) ---
# REQUIRED in production (the app throws at boot if left at the dev fallback while
# NODE_ENV=production). Generate a strong random secret for real deployments.
BETTER_AUTH_SECRET=dev-secret-change-me
# Base URL Better Auth issues callbacks/links against (defaults to localhost:PORT).
BETTER_AUTH_URL=http://localhost:3001
# Dev/TEST ONLY: when true, the API also accepts identity via an `x-user-id`
# header (no real session). MUST be false/unset in production.
AUTH_TEST_HEADER=false

# --- Payments ---
# noop is local/test-only and is intentionally rejected when NODE_ENV=production.
PAYMENTS_PROVIDER=noop
PAYMENTS_WEBHOOK_SECRET=dev-noop-secret
STRIPE_API_KEY=
PAYMENTS_SUCCESS_URL=http://localhost:5173/billing?status=success
PAYMENTS_CANCEL_URL=http://localhost:5173/billing?status=cancel

# --- Provider secrets (NEVER commit real values; leave blank for CI) ---
GEMINI_API_KEY=
HEYGEN_API_KEY=
HEYGEN_WEBHOOK_SECRET=
HEYGEN_RESOLUTION=720p

# --- S3 / R2 (only when STORAGE_PROVIDER=s3) ---
# S3_ENDPOINT: leave blank for AWS S3; set to R2/MinIO URL for non-AWS.
#   R2 example: https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT=
# S3_REGION: AWS region or 'auto' for Cloudflare R2.
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE: set to 'true' for R2 or MinIO (path-style URLs).
S3_FORCE_PATH_STYLE=false
# STORAGE_SIGNED_URL_TTL_SECONDS: minimum 1800 (30 min) per M2 provider-fetch
# window constraint. HeyGen can take up to 10 min; Remotion render up to 5 min.
STORAGE_SIGNED_URL_TTL_SECONDS=1800

# OpenRouter (IMAGE_PROVIDER=openrouter) — Gemini image models (Nano Banana)
OPENROUTER_API_KEY=
# Public attribution sent to OpenRouter; never put a secret here.
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=coji
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview
OPENROUTER_IMAGE_MODEL_DRAFT=
OPENROUTER_IMAGE_MODEL_MAX=
OPENROUTER_CHAT_MODEL=google/gemini-2.5-flash
