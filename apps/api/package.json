{
  "name": "@coji/api",
  "version": "0.3.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "module": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "build": "bun build src/server.ts --target bun --outdir dist",
    "test": "bun test",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=4096 tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed:dev": "bun run src/scripts/seed-dev.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@coji/shared": "workspace:*",
    "@elysiajs/cors": "~1.4.0",
    "@elysiajs/openapi": "~1.4.0",
    "@google/genai": "2.12.0",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "elysia": "~1.4.29",
    "jimp": "^1.6.1",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.52",
    "@types/bun": "^1.3.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.6.0"
  }
}
